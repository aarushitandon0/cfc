# Copy to .env and fill in. Never commit the real .env file.

# --- Storage backend ---------------------------------------------------
# "local"     -> JSON-file-backed store at local_data/db.json, no GCP needed
# "firestore" -> real GCP Firestore (requires GOOGLE_CLOUD_PROJECT + auth below)
DB_BACKEND=local
GOOGLE_CLOUD_PROJECT=swasthyasetu-hackathon

# Auth for DB_BACKEND=firestore (pick ONE):
#   1) run `gcloud auth application-default login` locally, leave this unset, or
#   2) download a service account key from the GCP Console and point to it here
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# --- Gemini (Layer 3 explain/translate/tag layer) -----------------------
# Free key from https://aistudio.google.com/apikey - no GCP billing required.
# Without this set, summaries/alert text fall back to a templated message
# and incident tagging falls back to an "other"/"medium" tag - the numeric
# forecast/score/recommend pipeline still runs fully either way.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Speech-to-Text + Translation (Layer 1 voice path) -------------------
# false -> MockSpeechService (no GCP needed, used for local dev/demo)
# true  -> RealSpeechService (Cloud Speech-to-Text + Translation API; enable
#          both APIs on GOOGLE_CLOUD_PROJECT and set up auth as above)
USE_REAL_SPEECH_APIS=false

# --- CORS (admin + staff dev servers) ------------------------------------
CORS_ALLOW_ORIGINS=["http://localhost:5173","http://localhost:5174"]
